# Application Environment
NODE_ENV=development
PORT=3500

# Public URL (for API documentation, CORS, etc.)
PUBLIC_URL=http://localhost:3500

# Database Connection
# Format: postgres://username:password@host:port/database_name
DATABASE_URL=postgres://your_username:your_password@localhost:5432/your_database_name

# JWT Secret for Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_at_least_64_characters_long_random_hex_string

# CORS Allowed Origins (comma separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Encryption Key for sensitive data (credentials, integration keys, etc.)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_encryption_key_at_least_64_characters_long_random_hex_string

# Optional: API Base URL for external API documentation
# API_BASE_URL=https://your-production-api.com

# Zernio Social Media API (https://zernio.com)
ZERNIO_API_KEY=sk_your_zernio_api_key_here

# TikTok API for Business / Marketing API (direct Ads + Ads Analytics connector)
TIKTOK_BUSINESS_APP_ID=your_tiktok_business_app_id_here
TIKTOK_BUSINESS_APP_SECRET=your_tiktok_business_app_secret_here
# Must match the Advertiser redirect URL registered in TikTok Business Developer.
TIKTOK_BUSINESS_REDIRECT_URI=http://localhost:3500/api/medsos/tiktok/callback

# RajaOngkir Shipping Cost API (managed logistics assistant for MyCommerSocial)
# Docs: https://rajaongkir.com/docs/shipping-cost/getting_started/apikey
RAJAONGKIR_SHIPPING_API_KEY=your_rajaongkir_shipping_api_key_here
# Optional override, default: https://rajaongkir.komerce.id/api/v1
# RAJAONGKIR_BASE_URL=https://rajaongkir.komerce.id/api/v1
