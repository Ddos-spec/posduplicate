# ==============================================
# PRODUCTION ENVIRONMENT - FRONTEND (VERCEL)
# ==============================================
# This is a production-ready template

# ==============================================
# BACKEND API URL - VPS
# ==============================================
# Full URL to your backend API
# IMPORTANT: Include /api at the end

# Option 1: VPS with IP address
# VITE_API_URL=http://123.456.789.012:3000/api

# Option 2: VPS with domain + SSL (RECOMMENDED)
# VITE_API_URL=https://api.yourdomain.com/api

# Replace with your actual VPS IP or domain
VITE_API_URL=http://YOUR_VPS_IP:3000/api

# Mobile/native app API URL.
# Usually this is the same public API URL as VITE_API_URL.
VITE_MOBILE_API_URL=https://api.yourdomain.com/api

# Android APK download URL shown on the login page
# Option 1: host the APK inside the frontend public/downloads folder
# VITE_ANDROID_APP_DOWNLOAD_URL=https://app.yourdomain.com/downloads/mypos-latest.apk
#
# Option 2: host the APK anywhere else
# VITE_ANDROID_APP_DOWNLOAD_URL=https://downloads.yourdomain.com/mypos-latest.apk

VITE_ANDROID_APP_DOWNLOAD_URL=https://YOUR_FRONTEND_DOMAIN/downloads/mypos-latest.apk

# ==============================================
# VERCEL DEPLOYMENT NOTES
# ==============================================
# Don't put this file in Vercel!
# Instead, set environment variable in Vercel dashboard:
#
# 1. Go to: Project Settings > Environment Variables
# 2. Add variables:
#    Name:  VITE_API_URL
#    Value: http://YOUR_VPS_IP:3000/api
#
#    Name:  VITE_MOBILE_API_URL
#    Value: https://api.yourdomain.com/api
#
#    Name:  VITE_ANDROID_APP_DOWNLOAD_URL
#    Value: https://YOUR_FRONTEND_DOMAIN/downloads/mypos-latest.apk
# 3. Select: Production, Preview, Development (all)
# 4. Redeploy if already deployed
#
# ==============================================

# ==============================================
# OPTIONAL SETTINGS
# ==============================================

# App version (for cache busting)
# VITE_APP_VERSION=1.0.0

# Enable debug mode (development only)
# VITE_DEBUG=false

# Google Analytics ID (if needed)
# VITE_GA_ID=G-XXXXXXXXXX

# Sentry DSN (for error tracking)
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx
